{
  "description": "Core diagnostic suite for aggregation pathology attribution",
  "args": {
    "dataset": "fashionmnist",
    "model": "mlp",
    "num_clients": 20,
    "rounds": 10,
    "local_epochs": 2,
    "batch_size": 64,
    "partition": "dirichlet",
    "dirichlet_alpha": 0.03,
    "train_subset_size": 0,
    "test_subset_size": 0,
    "seeds": [42, 43, 44, 45, 46],
    "variants": [
      "fedavg",
      "fedavgm",
      "fedadam",
      "ours_real_graph_k2",
      "ours_random_control_k2",
      "ours_shuffled_control_k2",
      "ours_uniform_control_k2",
      "ours_identity_control_k2",
      "ours_cluster_only_k2",
      "ours_graphfree_normclip",
      "ours_graphfree_cap",
      "ours_graphfree_reweight"
    ],
    "diagnostics_enable": true,
    "loo_enabled": true,
    "out_dir": "experiments_current/diagnostic_core_suite"
  }
}
