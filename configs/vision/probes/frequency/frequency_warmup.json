{
  "description": "General FL frequency suite with delayed graph-filter aggregation. Warmup rounds log graph-spectrum diagnostics but keep FedAvg weights and do not update graph EMA state.",
  "args": {
    "dataset": "fashionmnist",
    "model": "mlp",
    "num_clients": 5,
    "rounds": 6,
    "local_epochs": 1,
    "batch_size": 64,
    "seeds": [42, 43, 44],
    "partition": "dirichlet",
    "dirichlet_alpha": 0.1,
    "train_subset_size": 1000,
    "test_subset_size": 300,
    "variants": [
      "fedavg",
      "ours_knn_k2",
      "ours_random_matched_k2",
      "ours_dense",
      "ours_uniform"
    ],
    "warmup_rounds": 2,
    "conflict_mix": 0.2,
    "min_client_weight": 0.05,
    "out_dir": "experiments_current/phaseB_frequency_warmup_k2",
    "suite_tag": "phaseB_frequency_warmup_k2"
  }
}
