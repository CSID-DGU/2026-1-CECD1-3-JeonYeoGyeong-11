{
  "description": "Post cid-order-fix graph-filter-only smoke under the restored N20 collapse stress condition, extended to N50. Keeps server momentum off for all graph-filter variants.",
  "args": {
    "client_counts": [20, 50],
    "dataset": "fashionmnist",
    "model": "mlp",
    "rounds": 10,
    "local_epochs": 2,
    "batch_size": 64,
    "seeds": [42],
    "partition": "dirichlet",
    "dirichlet_alpha": 0.03,
    "train_subset_size": 1000,
    "test_subset_size": 1000,
    "knn_k": 1,
    "variants": [
      "fedavg",
      "ours_graph_filtered_knn_k1_lp0p25_fixed_tau",
      "ours_graph_filtered_knn_k1_lp0p5_fixed_tau",
      "ours_graph_filtered_knn_k1_fixed_tau",
      "ours_graph_filtered_magnitude_knn_k1_lp0p5_fixed_tau",
      "ours_graph_filtered_dense_lp0p5_fixed_tau",
      "ours_graph_filtered_random_matched_k1_lp0p5_fixed_tau"
    ],
    "warmup_rounds": 3,
    "aggregation_target": "graph_filtered_update",
    "conflict_mix": 0.0,
    "min_client_weight": 0.0,
    "disable_adaptive_tau": "true",
    "fixed_tau": 1.0,
    "server_momentum": 0.9,
    "ours_server_momentum": 0.0,
    "out_dir": "experiments_current/lowpass_stress_graph_filter_only_n20_n50_postfix",
    "sweep_tag": "lowpass_stress_graph_filter_only_postfix"
  }
}

