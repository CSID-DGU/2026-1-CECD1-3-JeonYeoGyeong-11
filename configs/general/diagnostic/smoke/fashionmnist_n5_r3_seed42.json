{
  "description": "Diagnostic smoke for report/plot/dashboard generation",
  "args": {
    "dataset": "fashionmnist",
    "model": "mlp",
    "num_clients": 5,
    "rounds": 3,
    "local_epochs": 1,
    "batch_size": 64,
    "partition": "dirichlet",
    "dirichlet_alpha": 0.1,
    "train_subset_size": 1000,
    "test_subset_size": 300,
    "seeds": [42],
    "variants": [
      "fedavg",
      "ours_knn_k2",
      "ours_random_matched_k2",
      "ours_uniform"
    ],
    "diagnostics_enable": true,
    "loo_enabled": true,
    "out_dir": "experiments_current/diagnostic_smoke_suite"
  }
}
