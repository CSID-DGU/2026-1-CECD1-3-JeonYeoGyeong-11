{
  "description": "Focused probe for graph sources built from tail layer slices. Negative graph_layer_start values count from the end of the parameter tensor list.",
  "args": {
    "dataset": "fashionmnist",
    "model": "mlp",
    "num_clients": 5,
    "rounds": 6,
    "local_epochs": 1,
    "batch_size": 64,
    "seeds": [42, 43, 44],
    "partition": "dirichlet",
    "dirichlet_alpha": 0.1,
    "train_subset_size": 1000,
    "test_subset_size": 300,
    "variants": [
      "fedavg",
      "ours_knn_k1_fixed_tau",
      "ours_tail_m2_knn_k1_fixed_tau",
      "ours_tail_m4_knn_k1_fixed_tau",
      "ours_layerwise_tail_m2_knn_k1_fixed_tau",
      "ours_random_matched_k1_fixed_tau"
    ],
    "warmup_rounds": 3,
    "conflict_mix": 0.2,
    "fixed_tau": 1.0,
    "min_client_weight": 0.05,
    "out_dir": "experiments_current/layer_slice_probe",
    "suite_tag": "layer_slice_probe"
  }
}
